# Copy to .env and fill in values before running.
# .env is gitignored — never commit real credentials.

# The coding task Solo-Coder should complete
TASK=Write a Python function that returns the nth Fibonacci number and add a pytest test for it.

# Ollama endpoint (default works when Ollama runs on the Docker host)
OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5-coder:3b

# GitHub push (leave blank to skip push)
GITHUB_PAT=
GITHUB_REPO=owner/repo
GITHUB_USER=solo-coder-bot
GITHUB_EMAIL=bot@solo-coder.local
